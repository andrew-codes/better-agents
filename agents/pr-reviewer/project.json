{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "pr-reviewer",
  "projectType": "application",
  "sourceRoot": "agents/pr-reviewer/src",
  "tags": ["scope:agent"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/.build"],
      "options": {
        "cwd": "agents/pr-reviewer",
        "command": "yarn rspack build -c rspack.config.mjs"
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "outputs": ["{projectRoot}/.dist"],
      "options": {
        "command": "yarn tsx tools/package-agent.ts agents/pr-reviewer"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint agents/pr-reviewer/src"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "agents/pr-reviewer",
        "command": "tsc -p tsconfig.json"
      }
    }
  }
}
